generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id            String             @id @default(uuid())
  email         String             @unique
  password      String
  name          String
  avatarUrl     String?            @db.Text
  title         String?
  showInGreeting Boolean  @default(true)
  role          String             @default("OPERATOR")
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  conversations Conversation[]     @relation("AssignedOperator")
  memberships   ProjectMember[]
  presences     OperatorPresence[]
  messages      Message[]
  authSessions  AuthSession[]
  accessTokenRevocations AccessTokenRevocation[]
  tokenRevocationState   UserTokenRevocation?
}

model AuthSession {
  id           String    @id @default(uuid())
  userId       String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  replacedById String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt])
  @@index([expiresAt])
}

model AccessTokenRevocation {
  id           String   @id @default(uuid())
  userId       String
  tokenJtiHash String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model UserTokenRevocation {
  id           String   @id @default(uuid())
  userId       String   @unique
  revokeBefore DateTime
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([revokeBefore])
}

model Project {
  id            String             @id @default(uuid())
  name          String
  widgetKey     String             @unique @default(uuid())
  createdAt     DateTime           @default(now())
  updatedAt     DateTime           @updatedAt
  conversations Conversation[]
  members       ProjectMember[]
  settings      ProjectSettings?
  quickReplies  QuickReply[]
  events        Event[]
  presences     OperatorPresence[]
  webhooks      Webhook[]
  autoActionRules    AutoActionRule[]
  autoActionTriggers AutoActionTrigger[]
}

model ProjectMember {
  id          String   @id @default(uuid())
  userId      String
  projectId   String
  projectRole String   @default("OPERATOR")
  createdAt   DateTime @default(now())
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Visitor {
  id            String         @id @default(uuid())
  email         String?
  name          String?
  country       String?
  device        String?
  referrer      String?
  notes         String?        @db.Text
  utmData       String?        @db.Text // JSON: {source, medium, campaign, term, content}
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  conversations Conversation[]
  pageViews     PageView[]
}

model Conversation {
  id         String    @id @default(uuid())
  projectId  String
  visitorId  String
  operatorId String?
  status     String    @default("OPEN")
  isPinned   Boolean   @default(false)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  operator   User?     @relation("AssignedOperator", fields: [operatorId], references: [id])
  visitor    Visitor   @relation(fields: [visitorId], references: [id])
  project    Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  messages   Message[]
}

model Message {
  id             String       @id @default(uuid())
  conversationId String
  sender         String
  text           String?      @db.Text
  type           String       @default("TEXT")
  attachmentUrl  String?      @db.Text
  isRead         Boolean      @default(false)
  isNote         Boolean      @default(false)
  mentions       String?      @db.Text // JSON array of userIds
  createdAt      DateTime     @default(now())
  senderId       String?
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user           User?        @relation(fields: [senderId], references: [id])

  @@index([conversationId, isNote])
}

model QuickReply {
  id        String   @id @default(uuid())
  projectId String
  title     String
  text      String   @db.Text
  shortcut  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model ProjectSettings {
  id               String   @id @default(uuid())
  projectId        String   @unique
  timezone         String   @default("Europe/Moscow")
  businessHours    String   @db.Text
  isAlwaysOnline   Boolean  @default(true)
  offlineMessage   String   @db.Text
  isOfflineForm    Boolean  @default(true)
  chatColor        String   @default("#6366f1")
  buttonPosition   String   @default("bottom-right")
  buttonStyle      String   @default("round")
  coloredHeader    Boolean  @default(false)
  onlineTitle      String   @default("Напишите нам, мы онлайн!")
  offlineTitle     String   @default("Сейчас мы оффлайн")
  welcomeText      String   @db.Text
  soundEnabled     Boolean  @default(true)
  showMobileButton Boolean  @default(true)
  showLogo         Boolean  @default(true)
  fileUpload       Boolean  @default(true)
  messengerMode    Boolean  @default(true)
  typingWatch      Boolean  @default(true)
  // SMTP / Email notifications
  smtpHost         String?
  smtpPort         Int?     @default(587)
  smtpUser         String?
  smtpPassword     String?
  smtpFrom         String?
  emailNotify      Boolean  @default(false)
  webhookEnabled   Boolean  @default(false)
  prechatFields    String   @db.Text
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  project          Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Event {
  id        String   @id @default(uuid())
  projectId String
  type      String   // CONVERSATION_CREATED, MESSAGE_SENT, OPERATOR_ASSIGNED, CONVERSATION_CLOSED
  payload   String   @db.Text
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model OperatorPresence {
  id         String   @id @default(uuid())
  userId     String
  projectId  String
  socketId   String
  isOnline   Boolean  @default(true)
  lastSeenAt DateTime @default(now())
  createdAt  DateTime @default(now())
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  project    Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model PageView {
  id        String   @id @default(uuid())
  visitorId String
  url       String
  title     String?
  createdAt DateTime @default(now())
  visitor   Visitor  @relation(fields: [visitorId], references: [id], onDelete: Cascade)
}

model Webhook {
  id        String   @id @default(uuid())
  projectId String
  url       String
  events    String   @db.Text // JSON array: ["new_message","new_conversation"]
  secret    String?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model AutoActionRule {
  projectId                  String
  id                         String
  name                       String
  isActive                   Boolean  @default(true)
  urlContains                String   @default("/")
  referrerContains           String   @default("")
  deviceContains             String   @default("")
  utmSource                  String   @default("")
  utmMedium                  String   @default("")
  utmCampaign                String   @default("")
  utmTerm                    String   @default("")
  delaySeconds               Int      @default(0)
  cooldownMinutes            Int      @default(30)
  oncePerConversation        Boolean  @default(true)
  maxTriggersPerConversation Int      @default(3)
  maxTriggersPerSession      Int      @default(2)
  message                    String   @db.Text
  createdAt                  DateTime @default(now())
  updatedAt                  DateTime @updatedAt

  project  Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  triggers AutoActionTrigger[]

  @@id([projectId, id])
  @@index([projectId, isActive])
}

model AutoActionTrigger {
  id            String   @id @default(uuid())
  projectId     String
  ruleId        String
  conversationId String
  visitorId     String
  sessionId     String?
  messageId     String?
  url           String?  @db.Text
  replied       Boolean  @default(false)
  replyMessageId String?
  replyAt       DateTime?
  createdAt     DateTime @default(now())

  project Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  rule    AutoActionRule @relation(fields: [projectId, ruleId], references: [projectId, id], onDelete: Cascade)

  @@index([projectId, createdAt])
  @@index([projectId, ruleId, createdAt])
  @@index([projectId, conversationId, createdAt])
  @@index([projectId, visitorId, createdAt])
  @@index([projectId, sessionId, createdAt])
  @@index([projectId, replied, createdAt])
}
