# Use MySQL connection string for Docker
DATABASE_URL="mysql://root:rootpassword@mysql:3306/livechat"
JWT_SECRET="your-super-secret-jwt-key"
PORT=3001
FRONTEND_URL="http://localhost:5173"
WIDGET_URL="http://localhost:5174"

# URL через который браузер скачивает загруженные файлы (аватары, вложения).
# Локально: http://localhost:8080  |  Продакшн: https://media.your-domain.com
MEDIA_BASE_URL="http://localhost:8080"

# Установить в true если MEDIA_BASE_URL обязателен (автоматически true в production)
ENFORCE_MEDIA_ORIGIN=false
